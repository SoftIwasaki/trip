    <script>
        // Countdown timer for departure
        function updateCountdown() {
            const departureDate = new Date('2025-09-27T05:30:00').getTime(); // 2025年に変更
            const now = new Date().getTime();
            const distance = departureDate - now;

            if (distance > 0) {
                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById('days').textContent = days;
                document.getElementById('hours').textContent = hours;
                document.getElementById('minutes').textContent = minutes;
                document.getElementById('seconds').textContent = seconds;
            } else {
                document.getElementById('countdownTimer').innerHTML = '<h2 style="color: #ffffff; background: rgba(231, 76, 60, 0.8); padding: 20px; border-radius: 15px; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">🎉 旅行スタート！楽しんでください！ 🎉</h2>';
            }
        }

        // Update countdown every second and start immediately
        updateCountdown(); // 即座に実行
        setInterval(updateCountdown, 1000);

        // Progress tracking
        function updateProgress() {
            const checkboxes = document.querySelectorAll('input[type="checkbox"]');
            const checkedBoxes = document.querySelectorAll('input[type="checkbox"]:checked');
            const progress = (checkedBoxes.length / checkboxes.length) * 100;
            
            document.getElementById('progressBar').style.width = progress + '%';
            document.getElementById('progressText').textContent = `冒険の準備: ${Math.round(progress)}% 完了 (${checkedBoxes.length}/${checkboxes.length})`;
            
            // Update excitement meter
            updateExcitement(progress);
            
            // Celebration when reaching milestones
            if (progress >= 25 && progress < 50 && !sessionStorage.getItem('milestone25')) {
                setTimeout(() => {
                    alert('🎉 25%達成！順調に準備が進んでいますね！');
                    sessionStorage.setItem('milestone25', 'true');
                }, 500);
            } else if (progress >= 50 && progress < 75 && !sessionStorage.getItem('milestone50')) {
                setTimeout(() => {
                    alert('🎊 半分完了！もうすぐ旅行ですね！');
                    sessionStorage.setItem('milestone50', 'true');
                }, 500);
            } else if (progress >= 75 && progress < 100 && !sessionStorage.getItem('milestone75')) {
                setTimeout(() => {
                    alert('🚀 75%完了！あと少しで準備万端です！');
                    sessionStorage.setItem('milestone75', 'true');
                }, 500);
            } else if (progress === 100 && !sessionStorage.getItem('milestone100')) {
                setTimeout(() => {
                    confetti();
                    alert('🎉🎊 完璧！すべての準備が完了しました！素晴らしい旅行になりそうですね！');
                    sessionStorage.setItem('milestone100', 'true');
                }, 500);
            }
        }

        // Update excitement meter based on progress
        function updateExcitement(progress) {
            const excitementFill = document.getElementById('excitementFill');
            const excitementText = document.getElementById('excitementText');
            
            // Set the width of excitement bar
            excitementFill.style.width = progress + '%';
            
            // Update text based on progress
            let excitementLevel = '';
            let emoji = '';
            
            if (progress === 0) {
                excitementLevel = 'ワクワク開始！';
                emoji = '🌱';
            } else if (progress < 25) {
                excitementLevel = 'だんだんワクワク！';
                emoji = '😊';
            } else if (progress < 50) {
                excitementLevel = 'ワクワクしてきた！';
                emoji = '😄';
            } else if (progress < 75) {
                excitementLevel = 'かなりワクワク！';
                emoji = '🤗';
            } else if (progress < 100) {
                excitementLevel = '超ワクワク！';
                emoji = '🚀';
            } else {
                excitementLevel = 'MAX興奮！旅行だー！';
                emoji = '🎉🎊✨';
            }
            
            excitementText.textContent = `みんなの気持ち: ${excitementLevel} ${Math.round(progress)}% ${emoji}`;
        }

        // Check if item is completed and animate
        function checkCompleted(checkbox) {
            const timelineItem = checkbox.closest('.timeline-item');
            if (checkbox.checked) {
                timelineItem.classList.add('completed');
                // Add celebration animation
                setTimeout(() => {
                    timelineItem.style.transform = 'scale(1.02)';
                    setTimeout(() => {
                        timelineItem.style.transform = 'scale(1)';
                    }, 300);
                }, 100);
            } else {
                timelineItem.classList.remove('completed');
            }
        }

        // Confetti animation for 100% completion
        function confetti() {
            const colors = ['#ff6b9d', '#c44569', '#f8b500', '#e55039', '#74b9ff'];
            for (let i = 0; i < 50; i++) {
                setTimeout(() => {
                    createConfettiPiece(colors[Math.floor(Math.random() * colors.length)]);
                }, i * 50);
            }
        }

        function createConfettiPiece(color) {
            const confetti = document.createElement('div');
            confetti.style.position = 'fixed';
            confetti.style.width = '10px';
            confetti.style.height = '10px';
            confetti.style.backgroundColor = color;
            confetti.style.left = Math.random() * window.innerWidth + 'px';
            confetti.style.top = '-10px';
            confetti.style.borderRadius = '50%';
            confetti.style.pointerEvents = 'none';
            confetti.style.zIndex = '9999';
            document.body.appendChild(confetti);

            let pos = -10;
            const fall = setInterval(() => {
                pos += 5;
                confetti.style.top = pos + 'px';
                if (pos > window.innerHeight) {
                    clearInterval(fall);
                    document.body.removeChild(confetti);
                }
            }, 20);
        }

        // Fun interactive features
        function playSound() {
            const songs = [
                "🎵 家族で歌おう「ふるさと」",
                "🎶 ドライブソング「津軽海峡冬景色」",
                "🎼 BBQ BGM「キャンプファイヤーソング」",
                "🎤 家族カラオケ「青春」"
            ];
            const randomSong = songs[Math.floor(Math.random() * songs.length)];
            alert(`${randomSong}\n\n♪ みんなで楽しく歌いましょう！`);
        }

        function showRandomTip() {
            const tips = [
                "💡 朝市は早い時間ほど品揃えが豊富！7時到着がベスト",
                "📸 瀬戸川の鯉は午前中の方が活発で写真映えします",
                "🍶 飛騨の地酒は「久寿玉」「蓬莱」がおすすめ",
                "🔥 焚き火は着火剤を使って息子さんに火起こしを教えてあげて",
                "🧖‍♂️ サウナ後の外気浴は最高！家族で整いましょう",
                "🥩 飛騨牛は表面をサッと焼いて中はレアがベスト",
                "📱 CoIUキャンパスは新しい教育の形。息子さんも興味深いはず"
            ];
            const randomTip = tips[Math.floor(Math.random() * tips.length)];
            alert(`旅行のコツ:\n\n${randomTip}`);
        }

        function takeFamilyPhoto() {
            const photoIdeas = [
                "📸 朝市での買い物シーン",
                "🍔 BBQハンバーガーと家族の笑顔",
                "🍃 朴葉味噌作りの様子",
                "🔥 焚き火を囲んでの家族団らん",
                "🏯 高山陣屋前での記念写真",
                "🌊 瀬戸川の鯉と一緒に",
                "👨‍👩‍👦 古い町並みでの家族写真"
            ];
            const randomIdea = photoIdeas[Math.floor(Math.random() * photoIdeas.length)];
            alert(`写真アイデア:\n\n${randomIdea}\n\nステキな思い出を残しましょう！`);
        }

        function addPhoto(photoType) {
            const photoTypes = {
                1: "朝市での家族写真",
                2: "BBQ & ハンバーガー作り",
                3: "古川散策の風景",
                4: "家族全員での記念写真"
            };
            alert(`${photoTypes[photoType]}の写真を追加しました！\n\n📱 実際の旅行では、たくさん写真を撮って素敵な思い出を作ってくださいね！`);
        }

        function saveNotes() {
            const notes = document.getElementById('travelNotes').value;
            if (notes.trim()) {
                localStorage.setItem('familyTravelNotes', notes);
                alert('📝 メモを保存しました！\n\n旅行中の大切な思い出や感想を記録しておきましょう。');
            } else {
                alert('メモに内容を入力してから保存してください。');
            }
        }

        // Load saved notes and checkbox states
        window.addEventListener('load', function() {
            const savedNotes = localStorage.getItem('familyTravelNotes');
            if (savedNotes) {
                document.getElementById('travelNotes').value = savedNotes;
            }

            // Load saved checkbox states
            const checkboxes = document.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(checkbox => {
                const savedState = localStorage.getItem(checkbox.id);
                if (savedState === 'true') {
                    checkbox.checked = true;
                    checkCompleted(checkbox);
                }
            });
            // Initialize excitement meter and progress
            updateProgress();
            updateExcitement(0);
        });

        // Save checkbox states
        document.addEventListener('change', function(e) {
            if (e.target.type === 'checkbox') {
                localStorage.setItem(e.target.id, e.target.checked);
            }
        });
    </script>
</body>
</html>
